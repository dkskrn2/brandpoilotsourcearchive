BRAND_PILOT_API_URL=http://localhost:4000
WORKER_API_TOKEN=
WORKER_ID=image-worker-pc-1
BLOB_READ_WRITE_TOKEN=
IMAGE_PROVIDER=command
# The command receives absolute job JSON and output directory paths.
# It is invoked once per job and must create one to five sequential slide-XX.png files.
IMAGE_RENDER_COMMAND=node scripts/run-codex-image-render.mjs --job "{{jobFile}}" --output "{{outputDir}}"
IMAGE_JOB_TIMEOUT_MS=1200000
IMAGE_MODEL=codex-imagegen
IMAGE_RETRY_DELAY_MS=300000
POLL_INTERVAL_MS=10000
HEARTBEAT_INTERVAL_MS=300000
WORKER_RESOURCE_POLL_INTERVAL_MS=1000
WORKER_RESOURCE_HEARTBEAT_INTERVAL_MS=15000

# Local-only worker control app. Opens on http://127.0.0.1:4174 by default.
WORKER_CONTROL_PORT=4174

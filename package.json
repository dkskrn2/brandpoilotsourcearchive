{
  "name": "brand-pilot",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "workers/*"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "predev:api": "npm run env:check -- --process=api",
    "dev:api": "npm run dev --workspace @brand-pilot/api",
    "predev:ui": "npm run env:check -- --process=ui",
    "dev:ui": "npm run dev --workspace @brand-pilot/customer-ui",
    "predev:worker": "npm run env:check -- --process=image-worker",
    "dev:worker": "npm run dev --workspace @brand-pilot/image-worker",
    "worker:once": "npm run run-once --workspace @brand-pilot/image-worker",
    "predev:dm-worker": "npm run env:check -- --process=dm-worker",
    "dev:dm-worker": "npm run dev --workspace @brand-pilot/dm-worker",
    "predev:dm-worker:1": "npm run env:check -- --process=dm-worker",
    "dev:dm-worker:1": "npm run dev:dm:1 --workspace @brand-pilot/dm-worker",
    "predev:dm-worker:2": "npm run env:check -- --process=dm-worker",
    "dev:dm-worker:2": "npm run dev:dm:2 --workspace @brand-pilot/dm-worker",
    "predev:wiki-worker": "npm run env:check -- --process=dm-worker",
    "dev:wiki-worker": "npm run dev:wiki --workspace @brand-pilot/dm-worker",
    "dm-worker:once": "npm run once --workspace @brand-pilot/dm-worker",
    "wiki-worker:once": "npm run once:wiki --workspace @brand-pilot/dm-worker",
    "worker:control": "npm run control --workspace @brand-pilot/image-worker",
    "predev:card-news-worker": "npm run env:check -- --process=card-news-worker",
    "dev:card-news-worker": "npm run dev --workspace @brand-pilot/card-news-worker",
    "card-news-worker:once": "npm run run-once --workspace @brand-pilot/card-news-worker",
    "predev:blog-worker": "npm run env:check -- --process=blog-worker",
    "dev:blog-worker": "npm run dev --workspace @brand-pilot/blog-worker",
    "blog-worker:once": "npm run run-once --workspace @brand-pilot/blog-worker",
    "predev:marketing-worker": "npm run env:check -- --process=marketing-worker",
    "dev:marketing-worker": "npm run dev --workspace @brand-pilot/marketing-worker",
    "marketing-worker:once": "npm run run-once --workspace @brand-pilot/marketing-worker",
    "predev:subject-analysis-worker": "npm run env:check -- --process=subject-analysis-worker",
    "dev:subject-analysis-worker": "npm run dev --workspace @brand-pilot/subject-analysis-worker",
    "subject-analysis-worker:once": "npm run run-once --workspace @brand-pilot/subject-analysis-worker",
    "predev:brand-intelligence-worker": "npm run env:check -- --process=brand-intelligence-worker",
    "dev:brand-intelligence-worker": "npm run dev --workspace @brand-pilot/brand-intelligence-worker",
    "brand-intelligence-worker:once": "npm run run-once --workspace @brand-pilot/brand-intelligence-worker",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:contract": "node --test scripts/repository-contract.test.mjs",
    "smoke:instagram-trends": "node scripts/instagram-trend-smoke.mjs",
    "smoke:compiled-wiki": "node scripts/compiled-wiki-smoke.mjs",
    "smoke:ai-content": "node scripts/ai-content-smoke.mjs",
    "smoke:ai-content-subject": "node scripts/ai-content-subject-smoke.mjs",
    "smoke:brand-intelligence": "node scripts/brand-intelligence-smoke.mjs",
    "test:migrations": "node --test scripts/migrations.integration.test.mjs",
    "test:topic-concurrency": "npm run test:topic-concurrency --workspace @brand-pilot/api",
    "test:e2e": "npm run e2e --workspace @brand-pilot/customer-ui",
    "env:check": "node scripts/check-local-env.mjs",
    "db:migrate": "node scripts/migrate.mjs",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4"
  }
}

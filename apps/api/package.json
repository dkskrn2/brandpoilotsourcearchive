{
  "name": "@brand-pilot/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && tsup src/index.ts --format esm --platform node --target node20 --out-dir dist --clean --sourcemap",
    "vercel-build": "npm run typecheck",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:topic-concurrency": "tsx src/topicQuota.postgres.integration.ts",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.4",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.15.6",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}

# Supabase transaction/session pooler connection string. Required in production.
SUPABASE_DATABASE_URL=

# Public brand logo storage. Keep the service role key only in the central API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BRAND_ASSETS_BUCKET=brand-assets

# Shared only by the central API and image worker.
WORKER_API_TOKEN=

# Growthline 관리자 서버 전용. 브라우저와 worker에서 사용하지 않습니다.
ADMIN_SERVICE_TOKEN=

# Vercel Cron 요청 인증과 호출당 자동 크롤링 한도입니다.
CRON_SECRET=
SOURCE_CRAWL_BATCH_SIZE=5
SOURCE_CRAWL_DISCOVERY_LIMIT=20
SOURCE_CRAWL_TIME_BUDGET_MS=45000
# 로컬 중앙 API의 분 단위 스케줄러를 실행합니다. 성과 수집은 매일 03:00 KST 이후
# 저장소가 당일 실행 여부를 판정하므로, 프로세스 재시작 후에도 다음 틱에서 보충 실행됩니다.
# 안전한 예제 기본값은 false입니다. Vercel에서도 이 스케줄러가 시작되지 않습니다.
LOCAL_SCHEDULER_ENABLED=false
WORKER_CODEX_MAX_CONCURRENCY=2
WORKER_CODEX_DM_RESERVED_SLOTS=1

# 32-byte base64, 64-character hex, or a passphrase of at least 32 bytes.
CREDENTIAL_ENCRYPTION_KEY=

INSTAGRAM_PUBLISH_ENABLED=true
IMAGE_JOB_COOLDOWN_MS=60000
META_GRAPH_VERSION=v23.0
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=http://localhost:4000/auth/meta/callback
# Facebook Login callback used only for public hashtag trend search.
# Use the same hosted HTTPS callback registered in Meta. The local UI starts
# this OAuth flow through VITE_META_TRENDS_CONNECT_URL on that hosted API.
META_TRENDS_OAUTH_REDIRECT_URI=https://your-api.example.com/auth/meta/trends/callback
META_WEBHOOK_VERIFY_TOKEN=
# Instagram DM sender profile data is refreshed asynchronously after this age.
DM_PROFILE_REFRESH_AFTER_HOURS=24
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:4000/auth/kakao/callback
AUTH_FRONTEND_URL=http://localhost:5173
BRAND_PILOT_DEV_BRAND_ID=00000000-0000-4000-8000-000000000100
BRAND_PILOT_DEV_WORKSPACE_ID=00000000-0000-4000-8000-000000000001

# AI 콘텐츠 첨부 파일 직접 업로드와 일일 사용 한도. Blob 토큰은 중앙 API에만 둡니다.
BLOB_READ_WRITE_TOKEN=
AI_CONTENT_DAILY_GENERATION_LIMIT=10
AI_CONTENT_DAILY_DOWNLOAD_LIMIT=20

# Vercel sets PORT, NODE_ENV and VERCEL automatically.
# Comma-separated trusted origins used for published artifact previews and downloads.
# Vercel Blob *.public.blob.vercel-storage.com URLs are allowed automatically.
PUBLISH_ARTIFACT_ALLOWED_ORIGINS=
# Brand intelligence analysis uses the shared WORKER_API_TOKEN through a dedicated local worker.
